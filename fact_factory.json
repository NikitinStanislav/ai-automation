      "parameters": {
        "jsCode": "// Access audio duration in seconds from previous node\nconst audioDuration = $json.audio_duration; // TTS length in seconds\nconst videoDuration = 964; // Total video length in seconds\n\nif (audioDuration >= videoDuration) {\n  throw new Error('TTS audio is longer than base video.');\n}\n\n// Pick a random start time that allows full audio to fit\nconst maxStart = videoDuration - audioDuration;\nconst startTime = Math.floor(Math.random() * maxStart);\nconst endTime = startTime + audioDuration;\n\nreturn [\n  {\n    json: {\n      start: startTime,\n      end: endTime,\n      duration: audioDuration\n    }\n  }\n];\n"
      },
